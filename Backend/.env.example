MONGO_URI=<mongodb-connection-string>
AWS_REGION=ap-south-1
DDB_TABLE_ADMINS=aaryaa-admins
DDB_TABLE_CONFIGS=aaryaa-configs
DDB_TABLE_PLANS=aaryaa-plans
